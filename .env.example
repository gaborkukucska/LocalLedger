# ==========================================
# 🇦🇺 LocaLedger Environment Configuration
# ==========================================

# ------------------------------------------
# 1. AI Capabilities
# ------------------------------------------
# OLLAMA_URL: Endpoint for your local, offline LLM model.
# Used for locally parsing and categorizing bank transactions.
# Ensure Ollama is running and has the 'llama3' (or equivalent) model pulled.
OLLAMA_URL="http://127.0.0.1:11434"

# ------------------------------------------
# 2. Server Configuration & Debugging
# ------------------------------------------
# DEBUG: Set to 'true' to enable extremely verbose logging in the application.
# Helpful if bank imports are failing or the AI fallback isn't routing correctly.
DEBUG="true"

# NODE_ENV: Set to 'production' or 'development'. Automatically set by Docker,
# but can be overridden if debugging native Node execution.
NODE_ENV="development"
